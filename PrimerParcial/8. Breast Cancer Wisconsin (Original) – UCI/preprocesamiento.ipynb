   "source": [
    "# Normalizo los datos usando Z-score\n",
    "# MUY IMPORTANTE: aprendo mu y sigma SOLO del train para evitar data leakage\n",
    "def normalizar(data, mu=None, sigma=None):\n",
    "    if mu is None:\n",
    "        mu = np.mean(data, axis=0)\n",
    "        sigma = np.std(data, axis=0)\n",
    "        sigma[sigma == 0] = 1\n",
    "    return (data - mu) / sigma, mu, sigma\n",
    "\n",
    "X_train, mu, sigma = normalizar(X_train_raw)\n",
    "X_test, _, _ = normalizar(X_test_raw, mu, sigma)\n",
    "\n",
    "print('=' * 50)\n",
    "print('DATOS LISTOS PARA USAR')\n",
    "print('=' * 50)\n",
    "print(f'X_train: {X_train.shape}')\n",
    "print(f'y_train: {y_train.shape}')\n",
    "print(f'X_test:  {X_test.shape}')\n",
    "print(f'y_test:  {y_test.shape}')\n",
    "print('=' * 50)"
   ]
