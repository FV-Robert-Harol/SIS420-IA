   "source": [
    "# Verifico si necesito balancear las clases con SMOTE\n",
    "# SMOTE crea datos sintéticos de la clase minoritaria\n",
    "# Solo lo uso si el desbalance es significativo (ratio > 1.5)\n",
    "from imblearn.over_sampling import SMOTE\n",
    "\n",
    "# Cuento las clases\n",
    "clase_0_antes = (y_train == 0).sum()\n",
    "clase_1_antes = (y_train == 1).sum()\n",
    "minoritaria = min(clase_0_antes, clase_1_antes)\n",
    "mayoritaria = max(clase_0_antes, clase_1_antes)\n",
    "\n",
    "print(f'ANTES del balanceo:')\n",
    "print(f'  Clase 0: {clase_0_antes}')\n",
    "print(f'  Clase 1: {clase_1_antes}')\n",
    "print(f'  Ratio: {mayoritaria/minoritaria:.2f}:1')\n",
    "\n",
    "# Solo balancear si hay desbalance significativo (ratio > 1.5)\n",
    "if mayoritaria / minoritaria > 1.5:\n",
    "    # Máximo duplicar la clase minoritaria (100% más)\n",
    "    max_minoritaria = minoritaria * 2\n",
    "    target_minoritaria = min(max_minoritaria, mayoritaria)\n",
    "    \n",
    "    sampling_strategy = target_minoritaria / mayoritaria\n",
    "    smote = SMOTE(sampling_strategy=sampling_strategy, random_state=42)\n",
    "    \n",
    "    X_train, y_train_flat = smote.fit_resample(X_train, y_train.ravel())\n",
    "    y_train = y_train_flat.reshape(-1, 1)\n",
    "    \n",
    "    clase_0_despues = (y_train == 0).sum()\n",
    "    clase_1_despues = (y_train == 1).sum()\n",
    "    \n",
    "    print(f'\\nDESPUÉS del balanceo con SMOTE:')\n",
    "    print(f'  Clase 0: {clase_0_despues}')\n",
    "    print(f'  Clase 1: {clase_1_despues}')\n",
    "    print(f'  Muestras añadidas: {len(y_train) - clase_0_antes - clase_1_antes}')\n",
    "else:\n",
    "    print('\\nNo se necesita balanceo (ratio < 1.5)')"
   ]
